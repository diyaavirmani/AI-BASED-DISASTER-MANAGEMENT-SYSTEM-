{
  "model_name": "LSTM_ZonePredictor",
  "version": "1.0",
  "task": "Binary classification \u2014 disaster risk prediction",
  "architecture": "Stacked LSTM (hidden=128, layers=2)",
  "input_shape": "(batch, 30, 22)",
  "output_shape": "(batch,)  \u2014 risk score 0-1",
  "features": [
    "temp_max",
    "temp_min",
    "temp_mean",
    "precipitation",
    "windspeed_max",
    "humidity",
    "precip_7d_sum",
    "precip_7d_mean",
    "temp_7d_mean",
    "wind_7d_max",
    "temp_anomaly",
    "precip_anomaly",
    "wind_anomaly",
    "quake_count",
    "max_magnitude",
    "mean_magnitude",
    "depth_mean",
    "log_seismic_energy",
    "seismic_7d_max",
    "seismic_7d_count",
    "days_since_sig_quake",
    "humid_x_precip"
  ],
  "n_features": 22,
  "lookback_days": 30,
  "horizon_days": 7,
  "best_auc_roc": 0.515625,
  "trained_epoch": 1,
  "val_metrics": {
    "auc_roc": 0.515625,
    "f1": 0.6666666666666666,
    "precision": 0.5,
    "recall": 1.0,
    "accuracy": 0.5
  },
  "data_sources": [
    "Open-Meteo (weather)",
    "USGS (seismic)",
    "GDACS (disaster records)"
  ],
  "training_zones": [
    "turkey-earthquake",
    "morocco-earthquake",
    "libya-flood",
    "hawaii-wildfire",
    "bata-explosion",
    "la-palma-volcano",
    "haiti-earthquake",
    "congo-volcano",
    "turkey-nodisaster",
    "morocco-nodisaster",
    "libya-nodisaster",
    "hawaii-nodisaster",
    "iran-nodisaster",
    "chile-nodisaster",
    "india-nodisaster",
    "brazil-nodisaster"
  ],
  "threshold_recommended": 0.3,
  "note": "Use threshold=0.3 for deployment \u2014 higher recall is preferred over precision for disaster prediction",
  "files": {
    "checkpoint": "/content/drive/MyDrive/lstm/models/checkpoints/LSTM_ZonePredictor_best.pth",
    "onnx": "/content/drive/MyDrive/lstm/models/checkpoints/LSTM_ZonePredictor.onnx",
    "scaler": "/content/drive/MyDrive/lstm/models/checkpoints/lstm_scaler.pkl"
  }
}